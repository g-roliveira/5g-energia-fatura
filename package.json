{
  "name": "5g-energia-fatura",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo 5G Energia Fatura — Go backend + Next.js frontend + Python extractor",
  "scripts": {
    "dev": "dotenv -e .env -- turbo run dev",
    "dev:raw": "bash scripts/dev.sh",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "cd services/backend-go && go run ./cmd/migrate",
    "format": "prettier --write \"**/*.{ts,tsx,go,json,yaml,yml,md}\""
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "web"
  ]
}
