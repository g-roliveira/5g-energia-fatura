    "prisma": "^7.7.0",
    "radix-ui": "latest",
    "react": "^19.2.4",
    "react-day-picker": "9.8.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.4",
